{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "Node16",
    "target": "ES2020",
    "allowJs": true,
    "noImplicitAny": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ES2020"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "strictPropertyInitialization": false,
    "moduleResolution": "node16"
  },
  "include": [
    "**/*.ts"
  ]
}